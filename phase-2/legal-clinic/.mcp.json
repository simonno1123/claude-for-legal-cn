{
  "mcpServers": {
    "legal-data": {
      "type": "stdio",
      "command": "node",
      "args": ["../../connectors/legal-data/server.js"],
      "title": "统一中国法律数据层 (占位)",
      "description": "提供法律法规、法条、案例、引用核验和案例权威排序；用于法律诊所的事实核验、法条定位和类案参考。",
      "env": {
        "LEGAL_DATA_PROVIDER": "${LEGAL_DATA_PROVIDER:auto}",
        "YUANDIAN_API_KEY": "${YUANDIAN_API_KEY}",
        "PKULAW_API_KEY": "${PKULAW_API_KEY}",
        "LAW_STAR_API_KEY": "${LAW_STAR_API_KEY}",
        "LOCAL_LEGAL_INDEX": "${LOCAL_LEGAL_INDEX:../../data/legal-index}"
      }
    },
    "wps-cloud-docs": {
      "type": "http",
      "url": "${WPS_CLOUD_DOCS_MCP_URL}",
      "title": "WPS / 金山文档 (占位)",
      "description": "读取当事人材料、授权委托材料、案件笔记和诊所教学文件。"
    },
    "cn-collaboration": {
      "type": "http",
      "url": "${CN_COLLAB_MCP_URL}",
      "title": "飞书 / 钉钉 / 企业微信 (占位)",
      "description": "用于诊所内部任务分派和复核提醒；不得自动发送涉隐私材料。"
    }
  },
  "recommendedCategories": [
    "china-legal-research",
    "legal-aid",
    "case-intake",
    "laws-regulations",
    "cases",
    "documents"
  ]
}
